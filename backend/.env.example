# Copy to backend/.env and fill in. NEVER commit .env.
PORT=3001

# --- LLM provider selection (src/llm.js is provider-agnostic) ---------------
# Which provider to call: anthropic | openai | gemini | mock
# `mock` needs no key — returns a canned valid Song for offline smoke/dev.
LLM_PROVIDER=anthropic

# Optional: override the model. Defaults per provider:
#   anthropic -> claude-haiku-4-5   (also fine: claude-sonnet-4-6)
#   openai    -> gpt-4o-mini
#   gemini    -> gemini-2.0-flash
# LLM_MODEL=claude-haiku-4-5

# --- Proxy (optional): route provider requests through an egress/corp proxy --
# Node's global fetch ignores HTTP(S)_PROXY, so the backend honors it explicitly
# via undici's ProxyAgent. Set LLM_PROXY (preferred) or the standard vars.
# Supports http/https proxy URLs, with optional user:pass@ credentials.
# LLM_PROXY=http://proxy.corp.local:3128
# (fallback order: LLM_PROXY > HTTPS_PROXY > HTTP_PROXY)

# --- API keys: set only the one for your chosen provider --------------------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
